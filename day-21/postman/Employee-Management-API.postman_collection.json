{
  "info": {
    "name": "Employee Management API",
    "description": "Complete API collection for the Employee Management System built with FastAPI.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "http://localhost:8000/register", "host": ["localhost"], "port": "8000", "path": ["register"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"samarth\",\n  \"email\": \"samarth@example.com\",\n  \"password\": \"secret123\",\n  \"role\": \"Admin\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "http://localhost:8000/login", "host": ["localhost"], "port": "8000", "path": ["login"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"samarth\",\n  \"password\": \"secret123\"\n}"
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "http://localhost:8000/me", "host": ["localhost"], "port": "8000", "path": ["me"]}
          }
        }
      ]
    },
    {
      "name": "Employees",
      "item": [
        {
          "name": "Get All Employees",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8000/employees?page=1&size=10", "host": ["localhost"], "port": "8000", "path": ["employees"], "query": [{"key": "page", "value": "1"}, {"key": "size", "value": "10"}]}
          }
        },
        {
          "name": "Get Employee by ID",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8000/employees/E001", "host": ["localhost"], "port": "8000", "path": ["employees", "E001"]}
          }
        },
        {
          "name": "Create Employee",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": {"raw": "http://localhost:8000/employees", "host": ["localhost"], "port": "8000", "path": ["employees"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Aman Sharma\",\n  \"email\": \"aman@example.com\",\n  \"department\": \"Engineering\",\n  \"salary\": 90000\n}"
            }
          }
        },
        {
          "name": "Update Employee",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": {"raw": "http://localhost:8000/employees/E001", "host": ["localhost"], "port": "8000", "path": ["employees", "E001"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"salary\": 95000\n}"
            }
          }
        },
        {
          "name": "Delete Employee",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "http://localhost:8000/employees/E001", "host": ["localhost"], "port": "8000", "path": ["employees", "E001"]}
          }
        },
        {
          "name": "Search Employees by Name",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8000/employees/search?name=Aman", "host": ["localhost"], "port": "8000", "path": ["employees", "search"], "query": [{"key": "name", "value": "Aman"}]}
          }
        },
        {
          "name": "Filter Employees by Department",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8000/employees/filter?department=Engineering", "host": ["localhost"], "port": "8000", "path": ["employees", "filter"], "query": [{"key": "department", "value": "Engineering"}]}
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8000/health", "host": ["localhost"], "port": "8000", "path": ["health"]}
          }
        }
      ]
    }
  ]
}